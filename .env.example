# Upstream madmail HTTP origin (Vite dev proxy only — not exposed to the browser bundle)
DEV_API_PROXY_TARGET=http://127.0.0.1:8080

# Route API calls through the Vite dev server (same origin, no CORS)
VITE_DEV_API_PROXY=1
VITE_DEV_API_PATH=/api/admin

# Phone testing on LAN (camera needs HTTPS — not http://192.168.x.x)
# VITE_DEV_HTTPS=1
# Then: bun run dev --host → open https://YOUR_LAN_IP:5173/ (accept cert warning)
